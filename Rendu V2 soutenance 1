// CALIBRATION MAGNÉTOMÈTRE — valeurs mesurées
//
// En faisant tourner le robot à 360°, le magnéto
// décrit une ellipse dans le plan X/Y.
// On mesure ses extrêmes pour corriger deux biais :
//
//   xOffset/yOffset : centre de l'ellipse
//     → compense le hard iron (champ parasite fixe
//       créé par les moteurs, vis, batteries...)
//
//   xScale/yScale : rayon de l'ellipse sur chaque axe
//     → compense le soft iron (déformation du champ
//       par les matériaux proches du capteur)
//
// Formule appliquée dans handleCap() :
//   nx  = (mx - xOffset) / xScale   → entre -1 et +1
//   ny  = (my - yOffset) / yScale   → entre -1 et +1
//   cap = atan2(-ny, nx) × 180/π    → 0° à 360°
//
// Résultat obtenu : Ratio X/Y = 1.03 ✓
const float CALIB_X_OFFSET = -2045.0;
const float CALIB_Y_OFFSET =   654.0;
const float CALIB_X_SCALE  =  1857.0;
const float CALIB_Y_SCALE  =  1922.0;


uint32_t tDerniereCorr = 0;

const float Kp = 0.8;   // moins agressif
const float Kd = 0.3;   // moins d'amortissement aussi
const int   INTERVALLE = 10;   // 10ms au lieu de 5ms → plus de ticks accumulés par cycle, mesure plus stable


// Variables globales — NE PAS remettre à zéro dans la boucle PD
long ecartPrecedent  = 0;
int  pwrDroitCourant  = 200;
int  pwrGaucheCourant = 200;

void corrigerPD() {
  if (commandeEnCours != "avancer" && commandeEnCours != "reculer") return;
  if (millis() - tDerniereCorr < 10) return;   // 10ms
  tDerniereCorr = millis();

  // Lecture atomique SANS remise à zéro
  noInterrupts();
  long ticksD = pasDroit;
  long ticksG = pasGauche;
  interrupts();

  // Écart cumulatif comme dans ton code original
  long  ecart      = ticksD - ticksG;
  float derivee    = ecart - ecartPrecedent;
  int   correction = (int)((ecart * Kp) + (derivee * Kd));
  ecartPrecedent   = ecart;

  int pwrD = constrain(pwrDroitCourant - correction, 0, 255);
  int pwrG = constrain(pwrGaucheCourant + correction, 0, 255);

  ledcWrite(canalDroit,  pwrD);
  ledcWrite(canalGauche, pwrG);
}

// FONCTION DE LOG 
//
// Envoie le message à la fois :
//   - sur le port série USB (si câble branché)
//   - au client Telnet connecté en WiFi
void logf(const char* format, ...) {
  char buf[128];
  va_list args;
  va_start(args, format);
  vsnprintf(buf, sizeof(buf), format, args);
  va_end(args);
  Serial.print(buf);
  if (telnetClient && telnetClient.connected())
    telnetClient.print(buf);
}

// GESTION TELNET
//
// Vérifie si un nouveau client veut se connecter.
// Si un ancien client est déjà là, on le déconnecte
// pour accepter la nouvelle connexion.
void checkTelnet() {
  if (telnetServer.hasClient()) {
    if (telnetClient && telnetClient.connected())
      telnetClient.stop();
    telnetClient = telnetServer.available();
  }
}

// UTILITAIRES I2C
// writeReg : écrit un octet dans un registre
// read16   : lit 2 octets consécutifs little-endian
//   (LSB en premier, MSB en second)
void writeReg(uint8_t addr, uint8_t reg, uint8_t val) {
  Wire.beginTransmission(addr);
  Wire.write(reg);
  Wire.write(val);
  Wire.endTransmission();
}

int16_t read16(uint8_t addr, uint8_t reg) {
  Wire.beginTransmission(addr);
  Wire.write(reg | 0x80);   // bit 7 à 1 → auto-incrément d'adresse
  Wire.endTransmission(false);
  Wire.requestFrom(addr, (uint8_t)2);
  uint8_t lo = Wire.read();
  uint8_t hi = Wire.read();
  return (int16_t)(hi << 8 | lo);
}

// INIT MAGNÉTOMÈTRE LIS3MDL
// CTRL1 0x70 : ultra-haute performance XY, ODR 10Hz
// CTRL2 0x00 : pleine échelle ±4 gauss
// CTRL3 0x00 : mode de mesure continu
// CTRL4 0x0C : ultra-haute performance Z
void initLIS3MDL() {
  writeReg(LIS3MDL_ADDR, LIS3_CTRL1, 0x70);
  writeReg(LIS3MDL_ADDR, LIS3_CTRL2, 0x00);
  writeReg(LIS3MDL_ADDR, LIS3_CTRL3, 0x00);
  writeReg(LIS3MDL_ADDR, LIS3_CTRL4, 0x0C);
  logf("LIS3MDL initialise\n");
}

// CALCUL DE VITESSE — appelé dans le loop()
//
// Toutes les INTERVALLE_VITESSE_MS ms, on lit les ticks
// accumulés depuis la dernière mesure et on calcule :
//
//   ticks/s  = delta_ticks / dt
//   cm/s     = (ticks/s) × CM_PAR_TICK
//   RPM      = (ticks/s) / TICKS_PAR_TOUR × 60
//
// On repart de la valeur courante (pas de remise à zéro)
// pour ne pas interférer avec les autres utilisations
// des compteurs (ticks GUI, PD futur, etc.)
void calculerVitesse() {
  if (millis() - tDerniereVit < INTERVALLE_VITESSE_MS) return;

  float dt = (millis() - tDerniereVit) / 1000.0;
  tDerniereVit = millis();

  noInterrupts();
  long d = pasDroit;
  long g = pasGauche;
  interrupts();

  float ticksParSecD = (d - pasDroitPrev)  / dt;
  float ticksParSecG = (g - pasGauchePrev) / dt;

  pasDroitPrev  = d;
  pasGauchePrev = g;

  // Conversion en cm/s et RPM
  vitesseDcms = ticksParSecD * CM_PAR_TICK;
  vitesseGcms = ticksParSecG * CM_PAR_TICK;
  vitesseDrpm = ticksParSecD / TICKS_PAR_TOUR * 60.0;
  vitesseGrpm = ticksParSecG / TICKS_PAR_TOUR * 60.0;
}



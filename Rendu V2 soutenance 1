// GÉOMÉTRIE DE LA ROUE — pour le calcul de vitesse
//
// Ces constantes permettent de convertir les ticks encodeur
// en grandeurs physiques réelles :
//
// TICKS_PAR_TOUR : nombre de fronts montants sur CH_A pour
//   un tour complet de roue. Mesuré à 1050.
//
// DIAM_ROUE_CM : diamètre de la roue en centimètres.
//   Permet de calculer la circonférence.
//
// CIRCONF_CM : distance parcourue en cm pour un tour complet
//   = π × diamètre = π × 9 ≈ 28.27 cm
//
// CM_PAR_TICK : distance réelle parcourue par tick
//   = circonférence / ticks par tour ≈ 0.0269 cm/tick
const float TICKS_PAR_TOUR = 1050.0;
const float DIAM_ROUE_CM   = 9.0;
const float CIRCONF_CM     = PI * DIAM_ROUE_CM;      // ≈ 28.27 cm
const float CM_PAR_TICK    = CIRCONF_CM / TICKS_PAR_TOUR; // ≈ 0.0269 cm/tick


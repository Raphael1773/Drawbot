#include <Arduino.h>
#include <ArduinoOTA.h>
#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>

// User led
//pour savoir si la carte marche ou non 
#define LEDU1 25
#define LEDU2 26

// Enable moteurs droit et gauche
// décident de la puissance envoyé au moteur: envoi une fréquence
// si impulsion large, moteur recoit beaucoup d'énergie donc puissance élevé donc tourne vite
// si impulsion courte, moteur recoit peu d'énergie donc peu de puissance donc tourne lentement
// Lorsqu'on utilise la pin, on déclare 3 chose:
//- la Fréquence: correspond à l'interrupteur de l'esp s'ouvre et se ferme 
//- la Résolution: correspond au nombre de bit sur la quelle on découpe la puissance ( 8 bit = coupé en 256 positions )
//- le rapport cyclique: c'est ce qu'on change pendnat que le robot roule, c'est le temps pendant lequel le courant reste allumé
// si on met 200, on sera à 80% de puissance
#define EN_D 23
#define EN_G 4

// Commande PWM moteur droit
// décide du sens de rotation du moteur, avant ou arrière en fonction des pins HIGH et LOW du moteur 1
#define IN_1_D 19
#define IN_2_D 18

// Commande PWM moteur gauche
// décide du sens de rotation du moteur, avant ou arrière en fonction des pins HIGH et LOW du moteur 2
#define IN_1_G 17
#define IN_2_G 16

// --- ENCODEURS QUADRATURE (RETROACTION) ---
// Les encodeurs permettent de mesurer la rotation réelle de l'axe moteur.
// Le modèle E1210GM possède un disque magnétique qui tourne devant deux capteurs à effet Hall.
// - Voie A (CH_A) : Envoie des impulsions quand le moteur tourne. En comptant les fronts, on connaît la distance/vitesse.
// - Voie B (CH_B) : Est décalée de 90° par rapport à la voie A. 
//   - Si A change avant B, le moteur tourne dans un sens.
//   - Si B change avant A, le moteur tourne dans l'autre sens.
// Encodeur gauche
#define ENC_G_CH_A 32
#define ENC_G_CH_B 33
// Encodeur droit
#define ENC_D_CH_A 27
#define ENC_D_CH_B 14

// I2C
// - SDA (Serial Data) : La ligne qui transporte les bits de données.
// - SCL (Serial Clock) : Le signal d'horloge qui synchronise l'envoi des données.
#define SDA 21
#define SCL 22

// Adresse I2C
#define ADDR_IMU 0x6B // Adresse du gyroscope/accéléromètre
#define ADDR_MAG 0x1E // Adresse de la boussole numérique

//Variable du Kd
// Amortissement de la correction (Dérivé)
//elle évite une correction trop brusque de la part du Kp
long ecartPrecedent = 0; 
float Kd = 0.8;

//Variables du Kp
// C'est la puissance de réaction immédiate. 
//Plus l'écart entre la cible et la position actuelle est grand, plus Kp va pousser fort pour corriger l'erreur  
//Commence à 0.5 ou 1.0
float Kp = 1.5; 


//Configuration Wifi
const char* ssid = "Draw_GOAAAT";
const char* password = "12345678";
WebServer server(80);

// Configuration des propriétés du PWM
const int freq = 5000;     // Fréquence de 5000 Hz
const int resolution = 8;  // Résolution de 8 bits (0 à 255)

// On définit deux canaux (0 et 1)
const int canalDroit = 0;
const int canalGauche = 1;

// Variables de comptage des encodeurs
volatile long pasDroit = 0;
volatile long pasGauche = 0;

// Fonctions d'interruption (comptage ultra-rapide en arrière-plan)
// Fais en sorte que les ordres n'aillent pas dans le flash mais dans la RAM pour aller plus vite 

void IRAM_ATTR ISR_Droit() { pasDroit++; }
void IRAM_ATTR ISR_Gauche() { pasGauche++; }

// Paramètres de l'escalier (71 ticks = 2cm pour 1000 ticks/tour et roues 90mm)
const int TICKS_2CM = 71;    
int TICKS_90DEG = 250; // Valeur à ajuster selon la largeur de ton robot

//-------------- TEST DE LA LIGNE DROITE -------------------


bool testEnCours = true;   // Pour ne faire le test qu'une seule fois
const long CIBLE_TICKS = 1000 ; // nombre de ticks fixés pour le test de la ligen droite 
int vitesseTest = 180;      // Puissance PWM (0-255)

void setup() {
  // Initialisation de la console pour voir ce qu'il se passe
  Serial.begin(115200); //vitesse communication ESP
  delay(100); 

  // --- INITIALISATION DES PINS -----------------------
  // On met toutes les pins de contrôle moteur en SORTIE
  pinMode(LEDU1, OUTPUT);
  pinMode(LEDU2, OUTPUT);
  pinMode(EN_D, OUTPUT);
  pinMode(EN_G, OUTPUT);
  pinMode(IN_1_D, OUTPUT);
  pinMode(IN_2_D, OUTPUT);
  pinMode(IN_1_G, OUTPUT);
  pinMode(IN_2_G, OUTPUT);

  // --- CONFIGURATION WIFI --------------
  Serial.println("Demarrage du mode Point d'Acces...");

  // Création du point d'acces Wifi
  WiFi.softAP(ssid, password);

  // On récupère l'adresse IP générée 
  IPAddress myIP = WiFi.softAPIP();
  
  Serial.print("Reseau WiFi cree : ");
  Serial.println(ssid);
  Serial.print("Adresse IP du robot : ");
  Serial.println(myIP);

  // Allumer la LED de statut pour confirmer que le WiFi est prêt
  digitalWrite(LEDU1, HIGH);

  // Lancement du serveur 
  server.begin();
  Serial.println("Serveur Web initialise.");

  // Programmation Oota
  // On donne un nom au robot pour qu'il apparaisse dans l'Arduino IDE
  ArduinoOTA.setHostname("Drawbooooooot"); 
  
  // On définit ce qu'il se passe pendant la mise à jour
  ArduinoOTA.onStart([]() {
    Serial.println("Début de la mise à jour à distance...");
  });
  ArduinoOTA.onEnd([]() {
    Serial.println("\nTerminé ! Redémarrage...");
  });

  // On lance le service d'écoute OTA
  ArduinoOTA.begin();

  //------------CONFIG DES PWM------------------

  // Configuration des canaux PWM
  ledcSetup(canalDroit, freq, resolution);
  ledcSetup(canalGauche, freq, resolution);

  // On lie les pins EN aux canaux
  ledcAttachPin(EN_D, canalDroit);
  ledcAttachPin(EN_G, canalGauche);

  //----------CONFIG ENCODEURS -----------------
  // Configuration des pins encodeurs
  pinMode(ENC_G_CH_A, INPUT_PULLUP);
  pinMode(ENC_G_CH_B, INPUT_PULLUP);
  pinMode(ENC_D_CH_A, INPUT_PULLUP);
  pinMode(ENC_D_CH_B, INPUT_PULLUP);

  // On attache les interruptions sur les pins A des encodeurs
  attachInterrupt(digitalPinToInterrupt(ENC_D_CH_A), ISR_Droit, RISING);
  attachInterrupt(digitalPinToInterrupt(ENC_G_CH_A), ISR_Gauche, RISING);

  // Initialisation I2C
  Wire.begin(SDA, SCL);

  // ----------SELF TEST POUR S'ASSURER DU FONCTIONNEMENT DES MOETURS ------------

//  Serial.println("Debut du Self-Test des moteurs...");

  // --- TEST MOTEUR DROIT ---
  //digitalWrite(IN_1_D, HIGH); // Sens avant
 // digitalWrite(IN_2_D, LOW);
  //(canalDroit, 200);   // On donne la puissance 
  //delay(500);                  // On tourne pendant 0.5 seconde
  //ledcWrite(canalDroit, 0);    // Stop
  
 // delay(500);                  // Petite pause entre les deux

  // --- TEST MOTEUR GAUCHE ---
  //digitalWrite(IN_1_G, HIGH); // Sens avant
  //digitalWrite(IN_2_G, LOW);
  //ledcWrite(canalGauche, 200);   // On donne la puissance
  //delay(500);                  // On tourne pendant 0.5 seconde
  //ledcWrite(canalGauche, 0);   // Stop

  //Serial.println("Self-Test termine");
}

void loop() {
  if (testEnCours) {
    if (pasDroit < CIBLE_TICKS) {
      
      //-----------------FONCTIONNEMENT PID -------------------------

      // 1. Calcul de l'écart (Erreur)
      // Si écart > 0, la roue gauche est en avance
      long ecart = pasGauche - pasDroit; 

      //Calcul d'une vitesse de variation en fonction de la puissance de correction
      float derivee = ecart - ecartPrecedent;
      
      // 2. Calcul de la correction
      int correction = (ecart * Kp) + (derivee * Kd);

      // On met à jour l'état de l'écart
      ecartPrecedent = ecart;

      // 3. Application des puissances
      int pwrDroit = 200;             // Puissance fixe pour la référence
      int pwrGauche = 200 - correction; // On ralentit le gauche s'il avance trop

      // Sécurité pour ne pas descendre en dessous de 0 ou dépasser 255
      pwrGauche = constrain(pwrGauche, 0, 255);

      // --- ENVOI AUX MOTEURS (Sens AVANT) ---
      digitalWrite(IN_1_D, LOW);  digitalWrite(IN_2_D, HIGH); 
      digitalWrite(IN_1_G, HIGH); digitalWrite(IN_2_G, LOW); 

      ledcWrite(canalDroit, pwrDroit);
      ledcWrite(canalGauche, pwrGauche);

      // Debug toutes les 100ms
      static uint32_t timer = 0;
      if (millis() - timer > 100) {
        Serial.printf("D:%ld G:%ld | Correction Gauche:%d\n", pasDroit, pasGauche, correction);
        timer = millis();
      }
    } 
    else {
      ledcWrite(canalDroit, 0);
      ledcWrite(canalGauche, 0);
      Serial.println("Erreur système... Non mdr c juste le code est fini");
      testEnCours = false;
    }
  }
  ArduinoOTA.handle();
}

// ───────────────────────────────────────────────
// LEDs utilisateur
// LED1 : carte alimentée et code actif
// LED2 : commande moteur en cours
// ───────────────────────────────────────────────
#define LEDU1 25
#define LEDU2 26

// ───────────────────────────────────────────────
// Enable moteurs droit et gauche (signal PWM)
// La largeur d'impulsion détermine la puissance :
//   large → beaucoup d'énergie → tourne vite
//   courte → peu d'énergie    → tourne lentement
// ───────────────────────────────────────────────
#define EN_D 23
#define EN_G  4

// ───────────────────────────────────────────────
// Pins de direction moteur droit
// IN1=LOW  / IN2=HIGH → sens avant
// IN1=HIGH / IN2=LOW  → sens arrière
// ───────────────────────────────────────────────
#define IN_1_D 19
#define IN_2_D 18

// ───────────────────────────────────────────────
// Pins de direction moteur gauche
// IN1=HIGH / IN2=LOW  → sens avant
// IN1=LOW  / IN2=HIGH → sens arrière
// ───────────────────────────────────────────────
#define IN_1_G 17
#define IN_2_G 16

// ───────────────────────────────────────────────
// Encodeurs quadrature — voie A uniquement
// Chaque front montant sur CH_A = 1 tick
// 1050 ticks = 1 tour complet de roue (70mm diam.)
//
// volatile  : le compilateur ne met jamais ces
//   variables en cache — elles peuvent changer
//   à tout moment via une interruption
// IRAM_ATTR : force les ISR en RAM plutôt qu'en
//   flash → exécution plus rapide, aucun tick manqué
// ───────────────────────────────────────────────
#define ENC_D_CH_A 27
#define ENC_G_CH_A 32

volatile long pasDroit  = 0;
volatile long pasGauche = 0;

void IRAM_ATTR ISR_Droit()  { pasDroit++;  }
void IRAM_ATTR ISR_Gauche() { pasGauche++; }

// ───────────────────────────────────────────────
// I2C — communication avec le magnétomètre
// SDA (pin 21) : ligne de données bit par bit
// SCL (pin 22) : horloge qui synchronise l'envoi
// ───────────────────────────────────────────────
#define SDA_PIN 21
#define SCL_PIN 22

// ───────────────────────────────────────────────
// Magnétomètre LIS3MDL
// Adresse I2C : 0x1E
// OUT_X_L : premier registre de sortie (LSB de X)
//   Les 6 octets suivants : X_L X_H Y_L Y_H Z_L Z_H
// ───────────────────────────────────────────────
#define LIS3MDL_ADDR 0x1E
#define LIS3_CTRL1   0x20
#define LIS3_CTRL2   0x21
#define LIS3_CTRL3   0x22
#define LIS3_CTRL4   0x23
#define LIS3_OUT_X_L 0x28

// ───────────────────────────────────────────────
// PARAMÈTRES PWM
// freq       : 5000 Hz
// resolution : 8 bits → 256 niveaux (0 à 255)
// canal 0    → moteur droit
// canal 1    → moteur gauche
// ───────────────────────────────────────────────
const int freq        = 5000;
const int resolution  = 8;
const int canalDroit  = 0;
const int canalGauche = 1;

// ───────────────────────────────────────────────
// COMPENSATION DE VITESSE MOTEURS
//
// Les moteurs n'ont pas exactement la même vitesse
// à puissance identique, et ce déséquilibre est
// différent en avant et en arrière (frottements
// et couple moteur asymétriques selon le sens).
//
// Mesuré en marche AVANT (même distance) :
//   Gauche : 36632 ticks / Droite : 36089 ticks
//   → Gauche 1.5% trop rapide
//   → PWR_GAUCHE_AV = 200 × (36089/36632) ≈ 197
//
// Mesuré en marche ARRIÈRE (même distance) :
//   Droite : 2071 ticks / Gauche : 1943 ticks
//   → Droite 6.2% trop rapide
//   → PWR_DROIT_AR = 200 × (1943/2071) ≈ 188
//
// PWR_FAIBLE : puissance réduite pour la roue
//   intérieure lors des virages
// ───────────────────────────────────────────────
const int PWR_DROIT_AV  = 200;   // avant   — référence
const int PWR_GAUCHE_AV = 197;   // avant   — gauche 1.5% trop rapide
const int PWR_DROIT_AR  = 183;   // arrière — référence
const int PWR_GAUCHE_AR = 200;   // arrière — gauche 3.6% trop rapide
const int PWR_FAIBLE    = 100;   // roue intérieure des virages


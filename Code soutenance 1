// APPLIQUE LA COMMANDE EN COURS AUX MOTEURS
//
// Chaque commande utilise les constantes adaptées
// à son sens de déplacement (AV ou AR) pour que
// la compensation de vitesse soit correcte dans
// les deux directions.
void appliquerCommande() {

  if (commandeEnCours == "avancer") {
    // Sens AVANT : gauche légèrement réduit (1.5% trop rapide)
    digitalWrite(IN_1_D, LOW);  digitalWrite(IN_2_D, HIGH);
    digitalWrite(IN_1_G, HIGH); digitalWrite(IN_2_G, LOW);
    ledcWrite(canalDroit,  PWR_DROIT_AV);
    ledcWrite(canalGauche, PWR_GAUCHE_AV);

  } else if (commandeEnCours == "reculer") {
    // Sens ARRIÈRE : droite légèrement réduit (6.2% trop rapide)
    digitalWrite(IN_1_D, HIGH); digitalWrite(IN_2_D, LOW);
    digitalWrite(IN_1_G, LOW);  digitalWrite(IN_2_G, HIGH);
    ledcWrite(canalDroit,  PWR_DROIT_AR);
    ledcWrite(canalGauche, PWR_GAUCHE_AR);

  } else if (commandeEnCours == "vag") {
    // VIRAGE AVANT GAUCHE : droite fort, gauche réduit (roue intérieure)
    digitalWrite(IN_1_D, LOW);  digitalWrite(IN_2_D, HIGH);
    digitalWrite(IN_1_G, HIGH); digitalWrite(IN_2_G, LOW);
    ledcWrite(canalDroit,  PWR_DROIT_AV);
    ledcWrite(canalGauche, PWR_FAIBLE);

  } else if (commandeEnCours == "vad") {
    // VIRAGE AVANT DROITE : gauche fort, droite réduit (roue intérieure)
    digitalWrite(IN_1_D, LOW);  digitalWrite(IN_2_D, HIGH);
    digitalWrite(IN_1_G, HIGH); digitalWrite(IN_2_G, LOW);
    ledcWrite(canalDroit,  PWR_FAIBLE);
    ledcWrite(canalGauche, PWR_GAUCHE_AV);

  } else if (commandeEnCours == "veg") {
    // VIRAGE ARRIÈRE GAUCHE : droite recule fort, gauche réduit
    digitalWrite(IN_1_D, HIGH); digitalWrite(IN_2_D, LOW);
    digitalWrite(IN_1_G, LOW);  digitalWrite(IN_2_G, HIGH);
    ledcWrite(canalDroit,  PWR_DROIT_AR);
    ledcWrite(canalGauche, PWR_FAIBLE);

  } else if (commandeEnCours == "ved") {
    // VIRAGE ARRIÈRE DROITE : gauche recule fort, droite réduit
    digitalWrite(IN_1_D, HIGH); digitalWrite(IN_2_D, LOW);
    digitalWrite(IN_1_G, LOW);  digitalWrite(IN_2_G, HIGH);
    ledcWrite(canalDroit,  PWR_FAIBLE);
    ledcWrite(canalGauche, PWR_GAUCHE_AR);

  } else if (commandeEnCours == "rotation_gauche") {
    // ROTATION GAUCHE sur place :
    //   droite avance (PWR_DROIT_AV) / gauche recule (PWR_GAUCHE_AR)
    digitalWrite(IN_1_D, LOW);  digitalWrite(IN_2_D, HIGH);
    digitalWrite(IN_1_G, LOW);  digitalWrite(IN_2_G, HIGH);
    ledcWrite(canalDroit,  PWR_DROIT_AV);
    ledcWrite(canalGauche, PWR_GAUCHE_AR);

  } else if (commandeEnCours == "rotation_droite") {
    // ROTATION DROITE sur place :
    //   gauche avance (PWR_GAUCHE_AV) / droite recule (PWR_DROIT_AR)
    digitalWrite(IN_1_D, HIGH); digitalWrite(IN_2_D, LOW);
    digitalWrite(IN_1_G, HIGH); digitalWrite(IN_2_G, LOW);
    ledcWrite(canalDroit,  PWR_DROIT_AR);
    ledcWrite(canalGauche, PWR_GAUCHE_AV);

  } else {
    // STOP : coupe complètement les deux moteurs
    ledcWrite(canalDroit,  0);
    ledcWrite(canalGauche, 0);
  }

  // LED2 allumée si un moteur tourne, éteinte si arrêt
  digitalWrite(LEDU2, commandeEnCours != "stop" ? HIGH : LOW);
}



// GESTIONNAIRES DU SERVEUR WEB

// Envoie la page HTML au navigateur
void handleRoot() {
  server.send_P(200, "text/html", PAGE_HTML);
}

// Reçoit une commande depuis le navigateur 
// Met à jour commandeEnCours 
void handleCmd() {
  if (server.hasArg("action")) {
    commandeEnCours = server.arg("action");
    logf("Commande : %s\n", commandeEnCours.c_str());
  }
  server.send(200, "text/plain", "ok");
}

// Retourne les valeurs BRUTES du magnétomètre (/mag/raw)
// Les 3 axes X Y Z en LSB (entiers signés 16 bits).
// Appelé par le GUI toutes les 200 ms.

void handleMagRaw() {
  int16_t mx = read16(LIS3MDL_ADDR, LIS3_OUT_X_L);
  int16_t my = read16(LIS3MDL_ADDR, LIS3_OUT_X_L + 2);
  int16_t mz = read16(LIS3MDL_ADDR, LIS3_OUT_X_L + 4);
  String json = "{\"mx\":" + String(mx) +
                ",\"my\":" + String(my) +
                ",\"mz\":" + String(mz) + "}";
  server.send(200, "application/json", json);
}

// Retourne les ticks des deux encodeurs (/ticks)
// noInterrupts/interrupts : lecture atomique pour
// éviter une valeur à moitié mise à jour si une
// interruption survient pendant la lecture.
void handleTicks() {
  noInterrupts();
  long d = pasDroit;
  long g = pasGauche;
  interrupts();
  String json = "{\"droite\":" + String(d) +
                ",\"gauche\":" + String(g) + "}";
  server.send(200, "application/json", json);
}


// Remet les deux compteurs à zéro (/ticks/reset)
// Appelé par le bouton "Remettre à zéro" du GUI.
void handleTicksReset() {
  noInterrupts();
  pasDroit  = 0;
  pasGauche = 0;
  interrupts();
  logf("Ticks remis a zero\n");
  server.send(200, "text/plain", "ok");
}

void setup() {
  Serial.begin(115200);
  delay(200);

  // LEDs : LED1 allumée dès le démarrage
  pinMode(LEDU1, OUTPUT); pinMode(LEDU2, OUTPUT);
  digitalWrite(LEDU1, HIGH);
  digitalWrite(LEDU2, LOW);

  // Moteurs : pins de direction en sortie + canaux PWM
  pinMode(IN_1_D, OUTPUT); pinMode(IN_2_D, OUTPUT);
  pinMode(IN_1_G, OUTPUT); pinMode(IN_2_G, OUTPUT);
  ledcSetup(canalDroit,  freq, resolution); ledcAttachPin(EN_D, canalDroit);
  ledcSetup(canalGauche, freq, resolution); ledcAttachPin(EN_G, canalGauche);

  // Encodeurs : INPUT_PULLUP évite les fausses lectures

  pinMode(ENC_D_CH_A, INPUT_PULLUP);
  pinMode(ENC_G_CH_A, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(ENC_D_CH_A), ISR_Droit,  RISING);
  attachInterrupt(digitalPinToInterrupt(ENC_G_CH_A), ISR_Gauche, RISING);

  // WiFi — doit démarrer AVANT le Telnet et le WebServer
  WiFi.softAP(ssid, password);

  // Telnet sur port 23 : Serial Monitor sans fil
  // → dans platformio.ini : monitor_port = socket://192.168.4.1:23
  telnetServer.begin();
  telnetServer.setNoDelay(true);

  // OTA : permet de téléverser le code en WiFi
  ArduinoOTA.begin();

  server.on("/",            handleRoot);
  server.on("/cmd",         handleCmd);
  server.on("/mag/raw",     handleMagRaw);
  server.on("/ticks",       handleTicks);
  server.on("/ticks/reset", handleTicksReset);
  server.begin();

  // I2C + magnétomètre
  Wire.begin(SDA_PIN, SCL_PIN);
  Wire.setClock(400000);
  initLIS3MDL();

  logf("Calibration chargee :\n");
  logf("  xOffset=%.1f  yOffset=%.1f\n", CALIB_X_OFFSET, CALIB_Y_OFFSET);
  logf("  xScale=%.1f   yScale=%.1f\n",  CALIB_X_SCALE,  CALIB_Y_SCALE);
  logf("GUI dispo sur : http://192.168.4.1\n");
  logf("Telnet        : socket://192.168.4.1:23\n\n");

  // LED2 clignote une fois : setup terminé, robot prêt
  digitalWrite(LEDU2, HIGH);
  delay(300);
  digitalWrite(LEDU2, LOW);
}

void loop() {
  server.handleClient();   // traite les requêtes HTTP
  ArduinoOTA.handle();     // vérifie les mises à jour OTA
  checkTelnet();           // accepte les nouvelles connexions Telnet
  appliquerCommande();     // applique la commande moteur en cours
}

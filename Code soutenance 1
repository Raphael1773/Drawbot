// CALIBRATION MAGNÉTOMÈTRE — valeurs mesurées

// X/Y. On mesure ses extrêmes pour calculer :
//
//   xOffset/yOffset : centre de l'ellipse
//     → compense le hard iron (champ parasite fixe
//       créé par les moteurs, vis, etc.)
//
//   xScale/yScale : rayon de l'ellipse sur chaque axe
//     → compense le soft iron (déformation du champ
//       par les matériaux proches du capteur)
//
// Formule de correction (appliquée dans handleMagRaw) :
//   nx  = (mx - xOffset) / xScale   → entre -1 et +1
//   ny  = (my - yOffset) / yScale   → entre -1 et +1
//   cap = atan2(-ny, nx) × 180/π    → 0° à 360°
//
// ───────────────────────────────────────────────
const float CALIB_X_OFFSET = -1833.5;
const float CALIB_Y_OFFSET =   753.5;
const float CALIB_X_SCALE  =  1691.5;
const float CALIB_Y_SCALE  =  1710.5;


// FONCTION DE LOG 
//
// Envoie le message à la fois :
//   - sur le port série USB (si câble branché)
//   - au client Telnet connecté en WiFi
void logf(const char* format, ...) {
  char buf[128];
  va_list args;
  va_start(args, format);
  vsnprintf(buf, sizeof(buf), format, args);
  va_end(args);
  Serial.print(buf);
  if (telnetClient && telnetClient.connected())
    telnetClient.print(buf);
}


// GESTION TELNET —
//
// Vérifie si un nouveau client veut se connecter.
// Si un ancien client est déjà là, on le déconnecte
// pour accepter la nouvelle connexion.
void checkTelnet() {
  if (telnetServer.hasClient()) {
    if (telnetClient && telnetClient.connected())
      telnetClient.stop();
    telnetClient = telnetServer.available();
  }
}

// UTILITAIRES I2C
// writeReg : écrit un octet dans un registre
// read16   : lit 2 octets consécutifs little-endian
//   (LSB en premier, MSB en second)

void writeReg(uint8_t addr, uint8_t reg, uint8_t val) {
  Wire.beginTransmission(addr);
  Wire.write(reg);
  Wire.write(val);
  Wire.endTransmission();
}

int16_t read16(uint8_t addr, uint8_t reg) {
  Wire.beginTransmission(addr);
  Wire.write(reg | 0x80);   // bit 7 à 1 → auto-incrément d'adresse
  Wire.endTransmission(false);
  Wire.requestFrom(addr, (uint8_t)2);
  uint8_t lo = Wire.read();
  uint8_t hi = Wire.read();
  return (int16_t)(hi << 8 | lo);
}


// INIT MAGNÉTOMÈTRE LIS3MDL
// CTRL1 0x70 : ultra-haute performance XY, ODR 10Hz
// CTRL2 0x00 : pleine échelle ±4 gauss
// CTRL3 0x00 : mode de mesure continu
// CTRL4 0x0C : ultra-haute performance Z
// ═══════════════════════════════════════════════
void initLIS3MDL() {
  writeReg(LIS3MDL_ADDR, LIS3_CTRL1, 0x70);
  writeReg(LIS3MDL_ADDR, LIS3_CTRL2, 0x00);
  writeReg(LIS3MDL_ADDR, LIS3_CTRL3, 0x00);
  writeReg(LIS3MDL_ADDR, LIS3_CTRL4, 0x0C);
  logf("LIS3MDL initialise\n");
}



